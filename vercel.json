{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/smart-farm/$1"
    }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "vercel-node@latest",
      "includeFiles": "artifacts/api-server/**"
    }
  }
}
